# ─── GhostShelf Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── General ──────────────────────────────────────────────────────────────────
DEBUG=false

# NOTE:
# Integration values below are optional fallback values.
# Preferred configuration is via UI: Settings page.

# ── Calibre-Web Automated ─────────────────────────────────────────────────────
# URL of your CWA / Calibre-Web instance
CWA_URL=http://calibre-web:8083

# Path to the CWA ingest / watch folder (where books are dropped for auto-import)
CWA_INGEST_FOLDER=/books/ingest

# ── Komga ─────────────────────────────────────────────────────────────────────
KOMGA_URL=http://komga:25600
KOMGA_USERNAME=admin@example.com
KOMGA_PASSWORD=changeme
KOMGA_INGEST_FOLDER=/comics/incoming
COMIC_INGEST_FOLDER=/comics/incoming
MANGA_INGEST_FOLDER=/manga/incoming

# ── Prowlarr ──────────────────────────────────────────────────────────────────
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# ── qBittorrent ───────────────────────────────────────────────────────────────
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# ── API Keys (optional) ────────────────────────────────────────────────────────
# Google Books: improves search quota (get at https://console.cloud.google.com)
GOOGLE_BOOKS_API_KEY=

# ComicVine: required for Western comics search (get at https://comicvine.gamespot.com/api/)
COMICVINE_API_KEY=
